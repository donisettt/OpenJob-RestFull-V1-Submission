{
  "name": "openjob-restful-api-v1",
  "version": "1.0.0",
  "description": "OpenJob RESTful API - Internal Recruitment Application",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "start:dev": "nodemon src/server.js",
    "migrate:up": "node-pg-migrate up",
    "migrate:down": "node-pg-migrate down",
    "migrate:create": "node-pg-migrate create",
    "db:reset": "node scripts/reset-db.js"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "chai": "^4.5.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "joi": "^17.13.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.12.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "node-pg-migrate": "^7.7.0",
    "nodemon": "^3.1.4"
  },
  "nodemonConfig": {
    "watch": [
      "src"
    ],
    "ext": "js",
    "ignore": [
      "node_modules",
      "uploads"
    ]
  }
}
